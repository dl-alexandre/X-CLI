#!/bin/sh
# Pre-commit hook for Go CLI projects
# This hook runs comprehensive checks that match CI pipeline

set -e

echo "🔍 Running pre-commit checks..."

# Check if we're in the root of a Go project
if [ ! -f "go.mod" ]; then
    echo "❌ Error: go.mod not found. Are you in the project root?"
    exit 1
fi

# Run formatting check
echo "  → Running go fmt..."
unformatted=$(gofmt -l .)
if [ -n "$unformatted" ]; then
    echo "❌ Error: The following files need formatting:"
    echo "$unformatted"
    echo "Run 'make format' to fix."
    exit 1
fi

# Run goimports if available
if command -v goimports >/dev/null 2>&1; then
    echo "  → Running goimports..."
    unformatted=$(goimports -l . 2>/dev/null | grep -v "vendor/" || true)
    if [ -n "$unformatted" ]; then
        echo "❌ Error: The following files need import formatting:"
        echo "$unformatted"
        echo "Run 'make format' or 'goimports -w .' to fix."
        exit 1
    fi
fi

# Run go vet
echo "  → Running go vet..."
if ! go vet ./... 2>&1; then
    echo "❌ Error: go vet found issues."
    exit 1
fi

# Run golangci-lint if available (matches CI)
if command -v golangci-lint >/dev/null 2>&1; then
    echo "  → Running golangci-lint..."
    if ! golangci-lint run --timeout=5m ./... 2>&1; then
        echo "❌ Error: golangci-lint found issues."
        echo "Run 'make lint' to see details."
        exit 1
    fi
else
    echo "⚠️  Warning: golangci-lint not installed. Install with:"
    echo "    go install github.com/golangci/golangci-lint/cmd/golangci-lint@latest"
fi

# Run security scan if available (matches CI)
if command -v gosec >/dev/null 2>&1; then
    echo "  → Running gosec security scan..."
    if ! gosec -quiet ./... 2>&1; then
        echo "❌ Error: gosec found security issues."
        echo "Run 'make security' to see details."
        exit 1
    fi
else
    echo "⚠️  Warning: gosec not installed. Install with:"
    echo "    go install github.com/securego/gosec/v2/cmd/gosec@latest"
fi

# Run tests
echo "  → Running tests..."
if ! go test -short ./... 2>&1; then
    echo "❌ Error: Tests failed."
    exit 1
fi

echo "✅ All checks passed!"
exit 0
